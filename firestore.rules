rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users collection ──
    // Authenticated users can only read/write their OWN document.
    // The `premium` field is written ONLY by Cloud Functions (admin SDK bypasses rules),
    // so the client cannot fake premium by editing its own users/{uid} doc.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.keys().hasAll(['phone', 'name', 'createdAt', 'platform'])
                    && request.resource.data.phone is string
                    && request.resource.data.name is string;
      // Client can only update name/lastLogin/lastUpdated. Premium is Cloud-Function-only.
      allow update: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['name', 'lastUpdated', 'lastLogin']);
      allow delete: if false; // Users cannot delete their profile
    }

    // ── Payments collection ──
    // Clients create with verified:false; admin (via Console or service account)
    // flips verified:true. Cloud Functions stamp processed metadata.
    // Clients MAY read their own payments to see status.
    match /payments/{paymentId} {
      allow create: if request.resource.data.verified == false
                    && request.resource.data.keys().hasAny(['deviceId', 'userId'])
                    && (request.resource.data.userId == null
                        || (request.auth != null && request.resource.data.userId == request.auth.uid));
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      // Clients cannot update or delete — admin-only via Console / service account.
      allow update, delete: if false;
    }

    // ── Claim codes collection ──
    // Issued by Cloud Functions when an anonymous payment is verified.
    // Users read by exact code (short-circuit brute force via short-lived + rate-limited
    // codes; 30-day expiry + 8-char unambiguous alphabet = ~5.7B space).
    // Update is one-time: claimed:false → true, claimedBy set to auth.uid.
    match /claim_codes/{code} {
      allow read: if request.auth != null;
      allow create, delete: if false; // Cloud Functions only
      allow update: if request.auth != null
                    && resource.data.claimed == false
                    && request.resource.data.claimed == true
                    && request.resource.data.claimedBy == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['claimed', 'claimedBy', 'claimedAt']);
    }

    // ── Analytics events collection ──
    // Anonymous create-only event log. Reads are done via Firebase Console /
    // BigQuery export, never from the client.
    // Schema enforced: event name + deviceId + platform + clientTs required.
    match /analytics_events/{eventId} {
      allow create: if request.resource.data.keys().hasAll(['event', 'deviceId', 'platform', 'clientTs'])
                    && request.resource.data.event is string
                    && request.resource.data.event.size() <= 60
                    && request.resource.data.deviceId is string
                    && request.resource.data.platform in ['web', 'ios', 'android', 'windows', 'macos'];
      allow read, update, delete: if false; // Admin only (via Console)
    }

    // ── Block all other collections ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
